---
layout: default
---
<div class="post">
  {%- comment -%}Styles for logo rows used in the collaborations/sponsors section{%- endcomment -%}
  <style>
    .logo-row { display: flex; flex-wrap: wrap; gap: 1.5rem 3rem; align-items: center; margin: 1.2rem 0 1.8rem 0; }
    .logo-row-lead { margin-bottom: 0.5rem; padding-bottom: 1rem; border-bottom: 1px solid #e0e0e0; }
    .logo-row a { display: flex; align-items: center; text-decoration: none; color: inherit; }
    .logo-row img { height: 55px; width: auto; max-width: 180px; object-fit: contain; filter: grayscale(15%); transition: filter 0.2s; }
    .logo-row a:hover img { filter: grayscale(0%); }
  </style>
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Project leadership banner -->
    {% assign team_lead = site.data.team | where: "role", "lead" | first %}
    {% assign team_pi   = site.data.team | where: "role", "pi"   | first %}
    {% if team_lead %}
      <div class="alert alert-info" role="alert" style="margin-bottom: 1.5rem;">
        <strong>Project Lead:</strong>
        <a href="{{ team_lead.url }}" target="_blank">{{ team_lead.name }}</a>
        ({{ team_lead.affiliation }}) &nbsp;&middot;&nbsp;
        <strong>PI:</strong>
        <a href="{{ team_pi.url }}" target="_blank">{{ team_pi.name }}</a>
        ({{ team_pi.affiliation }}) &nbsp;&middot;&nbsp;
        <a href="{{ '/team/' | relative_url }}">Meet the Team &rarr;</a>
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Collaborating Universities & Sponsors -->
    {% if page.collaborations %}
      {% if site.collaborations.lead_row.size > 0 or site.collaborations.collaborator_row.size > 0 %}
        <h2>Collaborating Universities</h2>
        <p>{{ site.collaborations.description }}</p>
        {% if site.collaborations.lead_row.size > 0 %}
          <div class="logo-row logo-row-lead">
            {% for org in site.collaborations.lead_row %}
              <a href="{{ org.url }}" target="_blank" title="{{ org.name }}">
                <img src="{{ org.logo | relative_url }}" alt="{{ org.name }}"{% if org.height %} style="height: {{ org.height }}"{% endif %} />
              </a>
            {% endfor %}
          </div>
        {% endif %}
        {% if site.collaborations.collaborator_row.size > 0 %}
          <div class="logo-row">
            {% for org in site.collaborations.collaborator_row %}
              <a href="{{ org.url }}" target="_blank" title="{{ org.name }}">
                <img src="{{ org.logo | relative_url }}" alt="{{ org.name }}"{% if org.height %} style="height: {{ org.height }}"{% endif %} />
              </a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
      {% if site.sponsors.size > 0 %}
        <h2>Sponsors</h2>
        <div class="logo-row">
          {% for sponsor in site.sponsors %}
            <a href="{{ sponsor.url }}" target="_blank" title="{{ sponsor.name }}">
              <img src="{{ sponsor.logo | relative_url }}" alt="{{ sponsor.name }}"{% if sponsor.height %} style="height: {{ sponsor.height }}"{% endif %} />
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

  </article>
</div>
